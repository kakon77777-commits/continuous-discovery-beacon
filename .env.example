CDB_APP_NAME=Continuous Discovery Beacon
CDB_ENV=development
CDB_DATABASE_URL=sqlite:///./data/cdb.sqlite3
CDB_PUBLIC_BASE_URL=http://localhost:8000
# Set a strong bearer token before exposing write APIs publicly.
CDB_API_TOKEN=change-me
CDB_INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow
CDB_REQUEST_TIMEOUT_SECONDS=10
CDB_MAX_DELIVERY_ATTEMPTS=5
CDB_RETRY_BASE_SECONDS=60
CDB_RETRY_MAX_SECONDS=3600
